{
  "manifest_version": 3,
  "name": "AI Prompt Logger",
  "version": "1.0.0",
  "description": "Logs prompts and responses from ChatGPT to a local backend.",
  "permissions": [],
  "host_permissions": [
    "http://127.0.0.1:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}