{
  "manifest_version": 3,
  "name": "AI Prompt Logger",
  "version": "1.0.0",
  "description": "Logs prompts and responses from ChatGPT to a remote backend.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://context-chrome-extension.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
